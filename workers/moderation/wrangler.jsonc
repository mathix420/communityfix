{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "communityfix-moderation",
  "main": "src/index.ts",
  "compatibility_date": "2025-12-22",
  "compatibility_flags": ["nodejs_compat"],
  "observability": {
    "enabled": true,
    "logs": { "enabled": true, "invocation_logs": true }
  },
  "workflows": [
    {
      "name": "moderation",
      "binding": "MODERATION_WORKFLOW",
      "class_name": "ModerationWorkflow"
    }
  ],
  "hyperdrive": [
    {
      "binding": "HYPERDRIVE",
      "id": "9cfe49d0e805462086e8365bd604a062"
    }
  ],
  "env": {
    "staging": {
      "name": "communityfix-moderation-staging",
      "workflows": [
        {
          "name": "moderation-staging",
          "binding": "MODERATION_WORKFLOW",
          "class_name": "ModerationWorkflow"
        }
      ],
      "hyperdrive": [
        {
          "binding": "HYPERDRIVE",
          "id": "d9a5e6878b9342b4ac96844524a59d05"
        }
      ]
    }
  }
}
