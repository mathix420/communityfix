{
  "$schema": "https://raw.githubusercontent.com/fallow-rs/fallow/main/schema.json",
  // Nuxt/wrangler/vitest entry points come from the active plugins;
  // these cover the standalone bits the plugins don't reach (root
  // config files like vize.config.ts have no plugin, so list them).
  "entry": [
    "scripts/*.ts",
    "workers/*/src/index.ts",
    "server/tasks/**/*.ts",
    "*.config.ts",
    "*.config.mjs"
  ],
  // Worker helpers (isAdminEmail/computeScore/StepDef) are exported but
  // only consumed within their own file — not dead, just over-exported.
  "ignoreExportsUsedInFile": true,
  // Deps used via Nuxt modules / CSS / icon-name strings instead of direct
  // imports, so static analysis can't see them: icons → @nuxt/icon,
  // takumi → nuxt-og-image, webauthn → nuxt-auth-utils, @nuxt/content module.
  "ignoreDependencies": [
    "@nuxt/content",
    "@simplewebauthn/browser",
    "@takumi-rs/core",
    "@takumi-rs/wasm",
    "@iconify-json/fa6-brands",
    "@iconify-json/simple-icons"
  ],
  "duplicates": {
    // Hide pair-only clones; focus on widespread copy-paste
    // worth refactoring. Lower to 2 to report every duplicate pair.
    "minOccurrences": 3
    // Common additions (uncomment to enable):
    // "ignore": [
    //   "**/lib/**",          // for repos that publish transpiled output to lib/
    //   "**/legacy/**",       // for repos with legacy-build artifacts
    //   "**/__generated__/**", // Relay, GraphQL Code Generator
    //   "**/generated/**"     // OpenAPI, Protobuf codegen
    // ]
  },
  "rules": {
    "unused-dependencies": "warn"
  }
}
